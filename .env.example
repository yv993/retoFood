# ----------------------------------------------------------------------------
# BurgerHouse — environment variables. Copy to .env.local and fill in.
# Everything is OPTIONAL: with no keys the site builds and runs, forms log to
# the server console (dev no-op), and the Pay button stays safely disabled.
# ----------------------------------------------------------------------------

# ---- Email (Resend) — powers reservation/catering/newsletter/gift/contact ----
# Get a key at https://resend.com. Without it, submissions are validated and
# logged server-side but no email is sent.
RESEND_API_KEY=
# Verified sender (must be a domain you've verified in Resend).
RESEND_FROM="BurgerHouse <orders@yourdomain.com>"
# Where form notifications are delivered.
CONTACT_EMAIL=hello@burgerhouse.am

# ---- Stripe — powers /checkout + catering deposit ----
# Without BOTH keys the Pay buttons are disabled with a clear message.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (Stripe Dashboard → Developers → Webhooks). Required for
# the /api/stripe/webhook route to persist paid orders + email receipts.
STRIPE_WEBHOOK_SECRET=
# Optional: catering "lock your date" deposit amount, in dram. Defaults to 50000.
CATERING_DEPOSIT_AMD=50000
# Optional: canonical origin used for Stripe success/cancel redirect URLs.
# Falls back to the request host. e.g. https://burgerhouse.am
NEXT_PUBLIC_SITE_URL=

# ---- Database (optional) ----
# The app ships with a zero-config store: a JSON file at .data/db.json in dev,
# falling back to in-memory in read-only environments (logged clearly). For a
# durable production database, set DATABASE_URL (Postgres) and follow
# DEPLOYMENT.md to switch src/lib/db.ts to Prisma. Leave blank to use the
# built-in store.
DATABASE_URL=

# ---- Admin dashboard (/admin) ----
# The single shared password for the staff dashboard. If unset, /admin is OPEN
# in development (for preview) and BLOCKED in production. Always set before deploy.
ADMIN_PASSWORD=

# ---- Analytics (optional, privacy-friendly, consent-gated) ----
# Set your Plausible site domain to enable analytics AFTER the user accepts cookies.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
